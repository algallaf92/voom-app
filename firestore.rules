rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // True when the caller is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // True when the caller is the owner of the document (userId field == uid).
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── matchmaking_queue ─────────────────────────────────────────────────────
    // Each signed-in user may manage only their own queue entry.
    // Any signed-in user may read the queue to find candidates.
    match /matchmaking_queue/{userId} {
      // Any authenticated user may read queue entries (needed for matching).
      allow read: if isSignedIn();

      // A user may create/update/delete only their own entry.
      allow create: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'waiting';

      allow update: if isSignedIn()
        // The owner may freely update their own entry (e.g., cancel).
        && (isOwner(userId)
          // Another signed-in user may only flip status to 'matched' and set
          // matchId when performing a claim inside a transaction. The entry
          // must currently be 'waiting' (prevents invalid state transitions).
          || (!isOwner(userId)
              && resource.data.status == 'waiting'
              && request.resource.data.status == 'matched'
              && request.resource.data.matchId is string
              // Only the matchId and status fields are allowed to change.
              && request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['status', 'matchId'])));

      allow delete: if isOwner(userId);
    }

    // ── matches ───────────────────────────────────────────────────────────────
    // A match document is created by one of the two participants during the
    // claiming transaction. Both participants may read and update it.
    match /matches/{matchId} {
      // Only participants may read a match.
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.user1Id
          || request.auth.uid == resource.data.user2Id);

      // The creating user sets up the match document during the transaction.
      allow create: if isSignedIn()
        && (request.resource.data.user1Id == request.auth.uid
          || request.resource.data.user2Id == request.auth.uid)
        && request.resource.data.status == 'active';

      // Either participant may update the match (e.g., mark it 'ended').
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.user1Id
          || request.auth.uid == resource.data.user2Id);

      allow delete: if false;
    }

    // ── users (user profiles) ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Deny all other collections by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
