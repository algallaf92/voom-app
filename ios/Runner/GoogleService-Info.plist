<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  IMPORTANT: This is a placeholder file.
  Replace it with the real GoogleService-Info.plist from Firebase Console:

  Step 1 – Open the Firebase Console:
    https://console.firebase.google.com/ → select your project

  Step 2 – Go to Project Settings:
    Click the ⚙ gear icon next to "Project Overview" → Project settings

  Step 3 – Find your iOS app:
    Scroll down to "Your apps". If no iOS app exists yet, click "Add app" → iOS+
    and register with bundle ID: com.example.voom
    (must match PRODUCT_BUNDLE_IDENTIFIER in ios/Runner.xcodeproj/project.pbxproj)

  Step 4 – Download the config file:
    Click "GoogleService-Info.plist" to download it.

  Step 5 – Replace this file:
    Copy the downloaded file to ios/Runner/GoogleService-Info.plist
    (overwrite this placeholder).

  Step 6 – Verify in Xcode (optional):
    Open ios/Runner.xcworkspace in Xcode.
    In the Project Navigator, confirm GoogleService-Info.plist appears under the Runner target.
    If it is missing, drag the file into the Runner group and make sure
    "Add to targets: Runner" is checked.

  Without a valid GoogleService-Info.plist the app will crash on launch on iOS
  because firebase_core cannot find the Firebase configuration.
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_WITH_YOUR_CLIENT_ID</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>REPLACE_WITH_YOUR_REVERSED_CLIENT_ID</string>
	<key>API_KEY</key>
	<string>REPLACE_WITH_YOUR_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_WITH_YOUR_GCM_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.example.voom</string>
	<!-- ↑ This matches PRODUCT_BUNDLE_IDENTIFIER in Runner.xcodeproj — update both together when you register a real bundle ID. -->
	<key>PROJECT_ID</key>
	<string>REPLACE_WITH_YOUR_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>REPLACE_WITH_YOUR_STORAGE_BUCKET</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>REPLACE_WITH_YOUR_GOOGLE_APP_ID</string>
</dict>
</plist>
